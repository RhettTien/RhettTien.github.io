      <description>在线小工具</description>
      <content:encoded><![CDATA[

<!DOCTYPE html>  
<html lang="en">  
<head>  
  <meta charset="UTF-8">  
  <meta name="viewport" content="width=device-width, initial-scale=1.0">  
  <title>NetMusic音乐下载</title>  
  <script src="/img/downmp3.js"></script>  
<style>
.urlname{
  text-indent: 10px;
  border-radius: 5px;
  width: 470px;
  height: 35px;
  font-size: 16px;
  color: #E20000;
  border: 2px solid #59f2a6;
}

.filename{
  font-size: 16px;
  text-indent: 10px;
  color: #E20000;
  border-radius: 5px;
  width: 470px;
  height: 35px;
  margin-top: 8px;
  border: 2px solid #59f2a6;
}

.titles{
  color: #E20000;
  font-weight: bold;
  font-size: 26px;
  font-family: FZYaoti;
}

.button{
  width: 80px;
  height: 40px;
  border-radius: 5px;
  border: 3px solid #ff7c3e;
  margin-top: 8px;
  font-size: 13px;
}

.placeholder{
  text-indent: 10px;
  border-radius: 5px;
  width: 170px;
  height: 35px;
  font-size: 16px;
  color: #E20000;
  border: 2px solid #59f2a6;
}

.placeholder2{
  font-size: 16px;
  text-indent: 10px;
  color: #E20000;
  border-radius: 5px;
  width: 180px;
  height: 35px;
  border: 2px solid #59f2a6;
}

.placeholder3{
  width: 50px;
  height: 40px;
  border-radius: 5px;
  border: 3px solid #ff7c3e;
  margin-top: 8px;
  font-size: 13px;
}

</style>
</head>  
<body>
  <div class="titles">下载网易云(非会员)的音乐</div>
  <input class="urlname" placeholder-class="placeholder" type="text" id="inputUrl" placeholder="粘贴分享链接" >
  <br>
  <input class="filename" placeholder-class="placeholder2" type="text" id="filename" placeholder="保存的文件名">  
  <button class="button" placeholder-class="placeholder3" onclick="downloadFile()">下载</button>  

  <script>  
    function downloadFile() {  
      var inputUrl = document.getElementById("inputUrl").value;
      var filename = document.getElementById("filename").value;	  
      var downloadUrl = processUrl(inputUrl); // 调用'url.js'中的函数处理地址  
      if (downloadUrl) {  
        // 创建隐藏的<a>元素并设置href和download属性  
        var downloadLink = document.createElement("a");  
        downloadLink.href = downloadUrl;  
        downloadLink.download = filename + ".mp3"; // 可根据需要更改文件名和扩展名  
        downloadLink.style.display = "none";  

        // 将<a>元素添加到DOM中并模拟点击下载  
        document.body.appendChild(downloadLink);  
        downloadLink.click();  
        document.body.removeChild(downloadLink);  
      } else {  
        alert("未找到有效的URL");  
      }  
    }  
  </script>  
</body>  
</html>


]]></content:encoded>
